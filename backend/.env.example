# === Void Occult backend — biến môi trường (MẪU) ===
# Sao chép thành .env rồi điền key:   cp .env.example .env
# (.env đã được .gitignore — KHÔNG commit.)

# Gemini API key (BẮT BUỘC). Lấy miễn phí: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model luận giải. Free tier hiện tại: gemini-2.5-flash
# (đổi gemini-2.5-flash-lite nếu bị giới hạn quota; gemini-2.0-flash đã khai tử 01/06/2026).
GEMINI_MODEL=gemini-2.5-flash

# Thinking mode (gemini-2.5-flash là model suy luận):
#   0 = tắt | -1 = động (model tự quyết, NHỚ nâng MAX_OUTPUT_TOKENS) | >0 = giới hạn token suy luận.
# BẮT BUỘC: MAX_OUTPUT_TOKENS >= THINKING_BUDGET + độ dài đáp án, nếu không câu trả lời sẽ bị cụt.
GEMINI_THINKING_BUDGET=8192
GEMINI_MAX_OUTPUT_TOKENS=24576

# CORS — origin frontend được phép gọi backend.
#   Dev nhanh: *  (cho phép tất cả; chỉ nên dùng local).
#   Chặt hơn: liệt kê, ngăn bằng dấu phẩy. VD: http://localhost:8080,http://127.0.0.1:8080
ALLOW_ORIGINS=*
# Bật mode debug khi dev (mở /api/debug/focus)
# VOIDOCC_DEBUG=1

# MongoDB for Persistence & Nghiệm Lý (Base-Rate System)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=void_occult
