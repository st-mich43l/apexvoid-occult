{
  "name": "void-occult",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:annual-axes-distribution:fast": "vitest run src/lib/ziwei/analysis/modules/annual-axes/audit",
    "audit:annual-axes-distribution": "ANNUAL_AXES_FULL_AUDIT=1 vitest run src/lib/ziwei/analysis/modules/annual-axes/audit/__tests__/full-audit.write.test.ts",
    "research:huyen-khi:validate-seed": "vitest run src/lib/ziwei/research/huyen-khi/__tests__/validate-seed.test.ts src/lib/ziwei/research/huyen-khi/__tests__/namespace-isolation.test.ts",
    "research:huyen-khi:import": "npx tsx src/lib/ziwei/research/huyen-khi/import-manual-record.ts",
    "research:huyen-khi:build-facts": "HUYEN_KHI_BUILD_REPORT=1 vitest run src/lib/ziwei/research/huyen-khi/__tests__/generate-report.write.test.ts",
    "research:huyen-khi:analyze": "HUYEN_KHI_BUILD_REPORT=1 vitest run src/lib/ziwei/research/huyen-khi/__tests__/generate-report.write.test.ts",
    "research:huyen-khi:validate-v02": "vitest run src/lib/ziwei/research/huyen-khi/__tests__/recover-v01-dates.test.ts src/lib/ziwei/research/huyen-khi/__tests__/gold-workflow.test.ts src/lib/ziwei/research/huyen-khi/__tests__/build-controlled-corpus-v02.test.ts src/lib/ziwei/research/huyen-khi/__tests__/build-chart-fact-snapshot-v02.test.ts",
    "research:huyen-khi:validate-v021": "vitest run src/lib/ziwei/research/huyen-khi/__tests__/validate-calendar-panel.test.ts src/lib/ziwei/research/huyen-khi/__tests__/compare-source-core.test.ts src/lib/ziwei/research/huyen-khi/__tests__/parse-menh-geometry.test.ts src/lib/ziwei/research/huyen-khi/__tests__/lunar-date-adjudication.test.ts src/lib/ziwei/research/huyen-khi/__tests__/output-scope-isolation.test.ts",
    "research:huyen-khi:build-reports-v021": "HUYEN_KHI_BUILD_REPORT_V02_1=1 vitest run src/lib/ziwei/research/huyen-khi/__tests__/generate-v0-2-1-reports.write.test.ts"
  },
  "dependencies": {
    "html-to-image": "1.11.13",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "ajv": "^8.20.0",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
