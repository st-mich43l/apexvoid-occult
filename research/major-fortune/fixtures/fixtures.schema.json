{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Major Fortune Core-Decade-Timing Fixtures V0.3",
  "description": "Hand-derived research expectations only. Must never be produced by calling engine-nam-phai.ts, engine-trung-chau.ts, or annual-flow.ts — every expected value here is worked out by hand from the resolved policy formulas (see ADR-MF-001..005) and recorded so a human can re-check the arithmetic.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "fixtureId": { "type": "string", "pattern": "^MF-FIX-[0-9]{3}$" },
          "category": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "input": {
            "type": "object",
            "additionalProperties": true
          },
          "expectedSelectedPolicies": {
            "type": "object",
            "additionalProperties": { "type": "string", "pattern": "^POL-MF-[A-Z0-9-]+$" }
          },
          "expectedDirection": { "type": "string", "enum": ["forward", "reverse", "not_applicable"] },
          "expectedStartingAge": { "type": ["number", "null"] },
          "expectedCycleIndex": {
            "anyOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string", "const": "unresolved" },
              { "type": "null" }
            ]
          },
          "expectedPalaceIndex": { "type": ["integer", "null"] },
          "manualDerivation": { "type": "string", "minLength": 1 },
          "sourceRefs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SRC-MF-[0-9]{3}$" }
          },
          "claimRefs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CLM-MF-[0-9]{3}$" }
          }
        },
        "required": [
          "fixtureId", "category", "description", "input",
          "expectedSelectedPolicies", "expectedDirection", "expectedStartingAge",
          "expectedCycleIndex", "expectedPalaceIndex", "manualDerivation",
          "sourceRefs", "claimRefs"
        ]
      }
    }
  },
  "required": ["fixtures"]
}
