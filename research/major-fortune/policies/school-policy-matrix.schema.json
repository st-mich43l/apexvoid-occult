{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "School Policy Matrix",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "policyId": { "type": "string", "pattern": "^POL-MF-[A-Z0-9-]+$" },
          "ruleId": { "type": "string", "pattern": "^RULE-MF-[A-Z0-9-]+$" },
          "topic": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "school": {
            "type": "string",
            "enum": ["bac-phai", "nam-phai", "mixed", "custom", "trung-chau", "unresolved"]
          },
          "status": {
            "type": "string",
            "enum": ["default", "supported", "experimental", "rejected", "unresolved"]
          },
          "calculationImpact": { "type": "boolean" },
          "interpretationImpact": { "type": "boolean" },
          "rule": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "parameters": { "type": "object" }
            },
            "required": ["type", "parameters"]
          },
          "sourceRefs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SRC-MF-[0-9]{3}$" }
          },
          "claimRefs": {
            "type": "array",
            "items": { "type": "string", "pattern": "^CLM-MF-[0-9]{3}$" }
          },
          "conflictsWith": {
            "type": "array",
            "items": { "type": "string", "pattern": "^POL-MF-[A-Z0-9-]+$" }
          },
          "defaultReason": { "type": "string" },
          "overrideAllowed": { "type": "boolean" },
          "implementationStatus": {
            "type": "string",
            "enum": ["not_started", "implemented", "tested"]
          },
          "legacyRuntimeRefs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "required": [
          "policyId", "ruleId", "topic", "label", "school", "status", "calculationImpact", "interpretationImpact", "rule", "sourceRefs", "claimRefs", "implementationStatus", "overrideAllowed"
        ]
      }
    }
  },
  "required": ["policies"]
}
