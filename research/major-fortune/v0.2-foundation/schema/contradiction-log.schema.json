{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Major Fortune V0.2 Contradiction Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "logId", "contradictions"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "logId": { "type": "string" },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contradictionId",
          "claimIds",
          "summary",
          "adjudication",
          "runtimeImplication",
          "sourceIds"
        ],
        "properties": {
          "contradictionId": { "type": "string", "pattern": "^CTR-MFV02-[0-9]{3}$" },
          "claimIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "adjudication": { "type": "string", "minLength": 1 },
          "runtimeImplication": { "type": "string", "minLength": 1 },
          "sourceIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    }
  }
}
