{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "readinessDecision",
    "authorizedShapeIds",
    "numericCandidatesEvaluated",
    "v01Unchanged",
    "productionRoutingUnchanged"
  ],
  "properties": {
    "readinessDecision": {
      "enum": [
        "READY_FOR_V0_2_CANDIDATE",
        "RESEARCH_INCOMPLETE",
        "BLOCKED_BY_CALCULATION_CORE"
      ]
    },
    "authorizedShapeIds": {
      "type": "array"
    },
    "numericCandidatesEvaluated": {
      "const": false
    },
    "v01Unchanged": {
      "const": true
    },
    "productionRoutingUnchanged": {
      "const": true
    }
  }
}
