{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schemaVersion",
    "registryId",
    "exactRawDeltaForbidden",
    "shapes"
  ],
  "properties": {
    "exactRawDeltaForbidden": {
      "const": true
    },
    "shapes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "shapeId",
          "authorizationStatus",
          "eligibleSchools",
          "includedRuleFamilies",
          "excludedRuleFamilies",
          "blockedRuleFamilies",
          "requiredCalculationCoreCapabilities",
          "signConstraints",
          "relativeOrderingConstraints",
          "allowedEngineeringCandidateRanges",
          "pillarBudgetConstraints",
          "unresolvedAssumptions",
          "invalidationConditions"
        ],
        "properties": {
          "shapeId": {
            "type": "string",
            "pattern": "^SHAPE-"
          },
          "authorizationStatus": {
            "enum": [
              "authorized",
              "not-authorized"
            ]
          },
          "includedRuleFamilies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "not": {
            "required": [
              "exactRawDelta",
              "rawDelta",
              "selectedRawDelta"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  }
}
