{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schemaVersion",
    "matrixId",
    "topics"
  ],
  "properties": {
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "topicId",
          "eligibility",
          "schools",
          "claimIds"
        ],
        "properties": {
          "eligibility": {
            "enum": [
              "candidate-eligible",
              "research-blocked",
              "blocked-by-calculation-core",
              "excluded-from-v0.2",
              "metadata-only"
            ]
          }
        }
      }
    }
  }
}
