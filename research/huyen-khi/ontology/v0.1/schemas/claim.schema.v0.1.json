{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "huyen-khi-claim.schema.v0.1.json",
  "type": "object",
  "required": [
    "claimId",
    "summary",
    "status",
    "sourceIds"
  ],
  "properties": {
    "claimId": {
      "type": "string",
      "pattern": "^HK-CLM-"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "approved-engineering",
        "approved-research-policy",
        "primary-source-reviewed",
        "secondary-source-reviewed",
        "expert-consensus",
        "experimental",
        "disputed",
        "unresolved"
      ]
    },
    "sourceIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "locator": {
      "type": "object"
    },
    "schoolProfiles": {
      "type": "array",
      "items": {
        "enum": [
          "shared",
          "nam-phai",
          "trung-chau"
        ]
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
